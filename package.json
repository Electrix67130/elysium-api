  },
  "homepage": "https://github.com/Electrix67130/elysium-api#readme",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "knex": "^3.1.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
