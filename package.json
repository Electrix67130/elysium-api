{
  "name": "elysium-api",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc",
    "migrate": "knex migrate:latest --knexfile src/config/knexfile.js",
    "migrate:make": "knex migrate:make --knexfile src/config/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile src/config/knexfile.js",
    "seed": "knex seed:run --knexfile src/config/knexfile.js",
    "seed:make": "knex seed:make --knexfile src/config/knexfile.js",
    "test": "jest --verbose",
    "test:unit": "jest --verbose tests/unit",
    "test:integration": "jest --verbose tests/integration"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Electrix67130/elysium-api.git"
  },
